# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요. (.env 는 git에 안 올라감)
# 로컬 테스트 전용 — GitHub Actions는 저장소 Secrets에서 같은 이름으로 읽습니다.

# Supabase 프로젝트 URL (config.js 에 있는 그 주소)
SUPABASE_URL=https://YOURPROJECT.supabase.co

# Supabase service_role 키 (RLS 우회 → matches 쓰기용). 절대 외부 노출 금지.
# Supabase 대시보드 > Project Settings > API > service_role 키
SUPABASE_SERVICE_KEY=여기에-service_role-키

# football-data.org 무료 API 토큰 (가입하면 메일/대시보드로 발급)
FOOTBALL_DATA_TOKEN=여기에-football-data-토큰

# (선택) 점검만 하고 DB엔 안 쓰려면 1. 평소엔 비워둠.
# DRY_RUN=1
